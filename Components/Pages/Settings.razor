@page "/admin/settings"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject BrandResolver Brands
@inject ConnectionConfig Conn
@inject PveDataService Data
@inject MonitorService Monitors

<PageTitle>@Loc.T("Einstellungen")</PageTitle>

<TopBar />

<div class="page-wrap">
    <h1>@Loc.T("Einstellungen")</h1>

    <h2>@Loc.T("Verbindungen") (PVE &amp; NPM)</h2>
    <p class="muted">@Loc.T("Wohin das Tool zugreift. So können auch andere es auf ihre eigene Proxmox/NPM-Instanz zeigen.")</p>
    <div class="settings-card">
        <div class="settings-grid">
            <label>PVE API-URL<input @bind="conn.PveBaseUrl" placeholder="https://host:8006/api2/json" /></label>
            <label>PVE API-Token<input type="password" @bind="conn.PveApiToken" placeholder="user@realm!id=secret" /></label>
            <label>NPM URL<input @bind="conn.NpmBaseUrl" placeholder="http://host:81" /></label>
            <label>@Loc.T("NPM Benutzer")<input @bind="conn.NpmUser" /></label>
            <label>@Loc.T("NPM Passwort")<input type="password" @bind="conn.NpmPassword" /></label>
            <label>@Loc.T("Backup-Ziel (Storage)")
                <select @bind="conn.BackupStorage">
                    <option value="">@Loc.T("(erstes verfügbares)")</option>
                    @foreach (var s in Data.BackupStorages)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </label>
            <label>Alert-Webhook (optional)<input @bind="conn.NotifyWebhook" placeholder="https://... (POST {&quot;text&quot;:...})" /></label>
            <label>Telegram Bot-Token (optional)<input type="password" @bind="conn.TelegramToken" placeholder="123456:ABC..." /></label>
            <label>Telegram Chat-ID (optional)<input @bind="conn.TelegramChatId" placeholder="@Loc.T("z.B. 12345678")" /></label>
        </div>
        <p class="muted" style="margin:.25rem 0 0">@Loc.T("Bei neuen Alerts (Pool voll, Guest down, Backup fehlt, Updates) wird — falls gesetzt — an Webhook und/oder Telegram gepusht.")</p>
        <button class="btn sm go" @onclick="SaveConn">@Loc.T("Speichern & neu laden")</button>
        @if (connMsg is not null)
        {
            <span class="muted" style="margin-left:1rem">@connMsg</span>
        }
    </div>

    <h2>@Loc.T("Monitore (eigene HTTP-Checks)")</h2>
    <p class="muted">@Loc.T("Beliebige URLs überwachen (nicht nur NPM-Domains). Down → Alert + Telegram/Webhook.")</p>
    <div class="settings-card">
        @foreach (var m in monitors)
        {
            <div class="user-row">
                <span class="uname">@m.Name</span>
                <span class="muted" style="flex:1">@m.Url</span>
                <span class="pill @(m.Enabled ? "on" : "off")">@(m.Enabled ? Loc.T("aktiv") : Loc.T("aus"))</span>
                <button class="btn xs" @onclick="() => ToggleMon(m.Id)">@(m.Enabled ? Loc.T("aus") : Loc.T("an"))</button>
                <button class="btn xs danger" @onclick="() => DeleteMon(m.Id)">@Loc.T("Löschen")</button>
            </div>
        }
        <div class="add-user">
            <input placeholder="@Loc.T("Name")" @bind="monName" />
            <input placeholder="https://…" @bind="monUrl" />
            <button class="btn sm go" @onclick="AddMon">@Loc.T("Hinzufügen")</button>
        </div>
    </div>

    <h2>@Loc.T("Welcome-Seiten")</h2>
    <p class="muted">@Loc.T("Pro Domain: Name, Tagline, Akzentfarbe und der externe Link. Host") <code>default</code> @Loc.T("greift, wenn keine Domain passt.")</p>

    @foreach (var b in brands)
    {
        <div class="settings-card">
            <div class="settings-host"><span class="dot" style="background:@b.Accent"></span> @b.Host</div>
            <div class="settings-grid">
                <label>@Loc.T("Name")<input @bind="b.Name" /></label>
                <label>Tagline<input @bind="b.Tagline" /></label>
                <label>@Loc.T("Akzent")<input type="color" @bind="b.Accent" /></label>
                <label>@Loc.T("Projekt-Link")<input @bind="b.ProjectsUrl" /></label>
            </div>
            <button class="btn sm go" @onclick="() => Save(b)">@Loc.T("Speichern")</button>
        </div>
    }

    <h2>@Loc.T("Neue Domain")</h2>
    <div class="add-brand">
        <input placeholder="@Loc.T("host (z.B. foo.de)")" @bind="newHost" />
        <input placeholder="@Loc.T("Name")" @bind="newName" />
        <button class="btn sm" @onclick="Add">@Loc.T("Hinzufügen")</button>
    </div>

    @if (msg is not null)
    {
        <p class="muted">@msg</p>
    }
</div>

@code {
    private List<BrandConfig> brands = [];
    private string newHost = "";
    private string newName = "";
    private string? msg;
    private ConnectionSettings conn = new();
    private string? connMsg;
    private List<UptimeMonitor> monitors = [];
    private string monName = "";
    private string monUrl = "";

    private async Task AddMon() { await Monitors.AddAsync(monName, monUrl); monName = ""; monUrl = ""; monitors = await Monitors.ListAsync(); await Data.RefreshAsync(); }
    private async Task ToggleMon(int id) { await Monitors.ToggleAsync(id); monitors = await Monitors.ListAsync(); await Data.RefreshAsync(); }
    private async Task DeleteMon(int id) { await Monitors.DeleteAsync(id); monitors = await Monitors.ListAsync(); await Data.RefreshAsync(); }

    protected override async Task OnInitializedAsync()
    {
        brands = await Brands.GetAllAsync();
        monitors = await Monitors.ListAsync();
        var c = Conn.Current;
        conn = new ConnectionSettings
        {
            Id = c.Id, PveBaseUrl = c.PveBaseUrl, PveApiToken = c.PveApiToken,
            NpmBaseUrl = c.NpmBaseUrl, NpmUser = c.NpmUser, NpmPassword = c.NpmPassword,
            BackupStorage = c.BackupStorage,
            NotifyWebhook = c.NotifyWebhook, TelegramToken = c.TelegramToken, TelegramChatId = c.TelegramChatId
        };
    }

    private async Task SaveConn()
    {
        await Conn.SaveAsync(conn);
        await Data.RefreshAsync();
        connMsg = Loc.T("Gespeichert. Daten werden neu geladen.");
    }

    private async Task Save(BrandConfig b)
    {
        await Brands.SaveAsync(b);
        msg = $"'{b.Host}' gespeichert.";
    }

    private async Task Add()
    {
        if (string.IsNullOrWhiteSpace(newHost)) { msg = Loc.T("Host nötig."); return; }
        await Brands.AddAsync(new BrandConfig { Host = newHost.Trim().ToLowerInvariant(), Name = string.IsNullOrWhiteSpace(newName) ? newHost : newName });
        newHost = ""; newName = "";
        brands = await Brands.GetAllAsync();
        msg = Loc.T("Domain hinzugefügt.");
    }
}
