@page "/resource/{VmId:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable
@inject PveDataService Data
@inject PveClient Pve
@inject IJSRuntime JS
@inject ConnectionConfig Conn

<PageTitle>@(guest?.Name ?? "Resource")</PageTitle>

<TopBar />

<div class="page-wrap">
    <a class="back" href="/dashboard">← Dashboard</a>

    @if (guest is null)
    {
        @if (Data.LastUpdated == default)
        {
            <p class="muted">Lade…</p>
        }
        else
        {
            <h1>Nicht gefunden</h1>
            <p class="muted">Keine Ressource mit #@VmId.</p>
        }
    }
    else
    {
        var served = Data.HostsFor(guest);
        <div class="detail-head">
            <div>
                <span class="kind big">@guest.Kind</span>
                <h1>@guest.Name <span class="vmid">#@guest.VmId</span></h1>
                <span class="pill @(guest.IsRunning ? "on" : "off")">@guest.Status</span>
            </div>
            <div class="actions">
                @if (guest.IsRunning)
                {
                    <button class="btn sm" disabled="@busy" @onclick='() => Act("reboot")'>Restart</button>
                    <button class="btn sm danger" disabled="@busy" @onclick='() => Act("shutdown")'>Stop</button>
                }
                else
                {
                    <button class="btn sm go" disabled="@busy" @onclick='() => Act("start")'>Start</button>
                }
                <button class="btn sm" disabled="@busy" @onclick="BackupNow">Backup jetzt</button>
                @if (Data.BackupFor(guest.VmId) is not null)
                {
                    <button class="btn sm danger" disabled="@(busy || guest.IsRunning)"
                            title="@(guest.IsRunning ? "zum Wiederherstellen erst stoppen" : "aus Backup wiederherstellen (überschreibt!)")"
                            @onclick="RestoreNow">Restore</button>
                }
            </div>
        </div>
        @if (bkpMsg is not null)
        {
            <p class="muted">@bkpMsg</p>
        }

        <section class="info-grid">
            <div><span class="label">Node</span><span class="val">@guest.Node</span></div>
            <div><span class="label">Typ</span><span class="val">@guest.Type (@guest.Kind)</span></div>
            <div><span class="label">IP</span><span class="val">@(guest.Ip ?? "–")</span></div>
            <div><span class="label">CPU</span><span class="val">@Format.Pct(guest.CpuFraction)</span><Sparkline Values="CpuHist" /></div>
            <div><span class="label">RAM</span><span class="val">@Format.Bytes(guest.MemUsed) / @Format.Bytes(guest.MemMax)</span><Sparkline Values="MemHist" Color="#38bdf8" /></div>
            <div><span class="label">Disk</span><span class="val">@Format.Bytes(guest.DiskUsed) / @Format.Bytes(guest.DiskMax)</span></div>
            <div><span class="label">Uptime</span><span class="val">@Format.Uptime(guest.Uptime)</span></div>
            <div><span class="label">Bedient</span><span class="val">@served.Count Domain(s)</span></div>
            <div><span class="label">Backup</span><span class="val">@BackupText()</span></div>
        </section>

        var gtasks = Data.Tasks.Where(t => t.VmId == guest.VmId).Take(6).ToList();
        @if (gtasks.Count > 0)
        {
            <h2>Aktivität</h2>
            <div class="tasks">
                @foreach (var t in gtasks)
                {
                    <div class="task @(t.IsRunning ? "run" : t.Ok ? "ok" : "err")">
                        <span class="tstate">@(t.IsRunning ? "läuft…" : t.Ok ? "✓" : "✗")</span>
                        <span class="tt">@t.Type</span>
                        <span class="ts muted">@t.Start.LocalDateTime.ToString("dd.MM HH:mm")</span>
                    </div>
                }
            </div>
        }

        <div class="res-head">
            <h2>Snapshots</h2>
            <button class="btn sm" disabled="@busy" @onclick="CreateSnap">＋ Snapshot</button>
        </div>
        @if (snapMsg is not null)
        {
            <p class="muted">@snapMsg</p>
        }
        @if (snaps.Count == 0)
        {
            <p class="muted">Keine Snapshots.</p>
        }
        else
        {
            <div class="snap-list">
                @foreach (var s in snaps)
                {
                    <div class="snap-row">
                        <span class="snap-name">@s.Name</span>
                        <span class="muted">@(s.Time?.LocalDateTime.ToString("dd.MM HH:mm") ?? "")@(string.IsNullOrEmpty(s.Description) ? "" : " · " + s.Description)</span>
                        <span class="snap-btns">
                            <button class="btn xs" disabled="@busy" @onclick="() => Rollback(s)">Rollback</button>
                            <button class="btn xs danger" disabled="@busy" @onclick="() => DeleteSnap(s)">Löschen</button>
                        </span>
                    </div>
                }
            </div>
        }

        <h2>Links</h2>
        <div class="links-list">
            <a class="link-card" href="@PveUiUrl" target="_blank" rel="noopener">
                <strong>Proxmox öffnen ↗</strong>
                <span class="muted">Verwaltung / Konsole im PVE-Webinterface</span>
            </a>

            @if (served.Count > 0)
            {
                @foreach (var h in served)
                {
                    @foreach (var d in h.DomainNames)
                    {
                        <a class="link-card" href="https://@d" target="_blank" rel="noopener">
                            <strong>@d ↗</strong>
                            <span class="muted">bedient von dieser Ressource (Port @h.ForwardPort · @(h.Online ? "online" : "offline"))</span>
                        </a>
                    }
                }
            }
            else if (guest.Ip is not null)
            {
                <div class="link-card muted-card">Keine NPM-Domain zeigt auf @guest.Ip.</div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int VmId { get; set; }

    private PveGuest? guest;
    private bool busy;
    private string? bkpMsg;
    private string? snapMsg;
    private IReadOnlyList<RrdPoint> rrd = [];
    private List<Snapshot> snaps = [];

    private IReadOnlyList<double> CpuHist => rrd.Select(p => p.Cpu).ToList();
    private IReadOnlyList<double> MemHist => rrd.Select(p => p.Mem).ToList();

    private async Task BackupNow()
    {
        if (guest is null) return;
        var target = Data.BackupTarget;
        if (string.IsNullOrEmpty(target)) { bkpMsg = "Kein Backup-Ziel konfiguriert — in Settings wählen."; return; }
        if (!await JS.InvokeAsync<bool>("confirm", $"Backup von {guest.Name} auf '{target}' starten?")) return;
        var ok = await Data.TriggerBackupAsync(guest);
        bkpMsg = ok ? $"Backup → '{target}' gestartet (erscheint in ein paar Minuten)." : "Backup-Start fehlgeschlagen.";
    }

    private async Task RestoreNow()
    {
        if (guest is null) return;
        if (guest.IsRunning) { bkpMsg = "Zum Wiederherstellen erst die Ressource stoppen."; return; }
        var b = Data.BackupFor(guest.VmId);
        if (b is null) { bkpMsg = "Kein Backup vorhanden."; return; }
        var warn = guest.Name == "core" ? "\n\nACHTUNG: core hostet Proxy/Tunnel + diese App — ein Restore killt ALLES!" : "";
        var typed = await JS.InvokeAsync<string>("prompt",
            $"WARNUNG: {guest.Name} (#{guest.VmId}) wird KOMPLETT mit dem Backup vom {b.Time.LocalDateTime:yyyy-MM-dd HH:mm} überschrieben. Der aktuelle Zustand geht unwiderruflich verloren.{warn}\n\nZum Bestätigen den Namen exakt tippen: {guest.Name}");
        if (typed != guest.Name) { bkpMsg = "Restore abgebrochen (Name nicht bestätigt)."; return; }
        busy = true;
        StateHasChanged();
        var err = await Data.RestoreAsync(guest);
        busy = false;
        bkpMsg = err is null
            ? "Restore gestartet — läuft im Hintergrund (im Proxmox-Task/Konsole beobachten)."
            : $"Restore fehlgeschlagen: {err}";
    }

    private string PveUiUrl => Conn.Current.PveBaseUrl.Replace("/api2/json", "");

    protected override async Task OnInitializedAsync()
    {
        Data.Changed += OnChanged;
        if (Data.LastUpdated == default) await Data.RefreshAsync();
        Resolve();
        await LoadExtras();
    }

    protected override void OnParametersSet() => Resolve();

    private void Resolve() => guest = Data.Guests.FirstOrDefault(g => g.VmId == VmId);

    /// Per-guest history + snapshots (fetched on demand, not cached for all guests).
    private async Task LoadExtras()
    {
        if (guest is null) return;
        rrd = await Pve.GetGuestRrdAsync(guest.Node, guest.Type, guest.VmId);
        snaps = await Pve.GetSnapshotsAsync(guest.Node, guest.Type, guest.VmId);
    }

    private async Task CreateSnap()
    {
        if (guest is null) return;
        var name = await JS.InvokeAsync<string>("prompt", "Snapshot-Name (Buchstabe zuerst, dann Buchstaben/Ziffern/_):", $"snap{DateTime.Now:MMddHHmm}");
        if (string.IsNullOrWhiteSpace(name)) return;
        busy = true; StateHasChanged();
        var err = await Pve.CreateSnapshotAsync(guest.Node, guest.Type, guest.VmId, name.Trim(), null);
        snaps = await Pve.GetSnapshotsAsync(guest.Node, guest.Type, guest.VmId);
        busy = false;
        snapMsg = err is null ? $"Snapshot '{name}' erstellt." : $"Fehlgeschlagen: {err}";
    }

    private async Task Rollback(Snapshot s)
    {
        if (guest is null) return;
        var warn = guest.IsRunning ? "\n\nGuest läuft — Rollback verwirft den aktuellen Zustand." : "";
        if (!await JS.InvokeAsync<bool>("confirm", $"Auf Snapshot '{s.Name}' zurückrollen? Der aktuelle Zustand geht verloren.{warn}")) return;
        busy = true; StateHasChanged();
        var err = await Pve.RollbackSnapshotAsync(guest.Node, guest.Type, guest.VmId, s.Name);
        busy = false;
        snapMsg = err is null ? $"Rollback auf '{s.Name}' gestartet (im Task/Konsole beobachten)." : $"Rollback fehlgeschlagen: {err}";
    }

    private async Task DeleteSnap(Snapshot s)
    {
        if (guest is null) return;
        if (!await JS.InvokeAsync<bool>("confirm", $"Snapshot '{s.Name}' löschen?")) return;
        busy = true; StateHasChanged();
        var err = await Pve.DeleteSnapshotAsync(guest.Node, guest.Type, guest.VmId, s.Name);
        snaps = await Pve.GetSnapshotsAsync(guest.Node, guest.Type, guest.VmId);
        busy = false;
        snapMsg = err is null ? $"Snapshot '{s.Name}' gelöscht." : $"Löschen fehlgeschlagen: {err}";
    }

    private string BackupText()
    {
        var b = Data.BackupFor(VmId);
        return b is null ? "– (keins)" : $"{b.Time.LocalDateTime:yyyy-MM-dd HH:mm} · {Format.Bytes(b.Size)}";
    }

    private void OnChanged() => InvokeAsync(() => { Resolve(); StateHasChanged(); });

    private async Task Act(string action)
    {
        if (guest is null) return;
        if (action is "shutdown" or "reboot")
        {
            var verb = action == "shutdown" ? "stoppen" : "neu starten";
            var warn = guest.Name == "core" ? " ⚠ core hostet Proxy + Tunnel — dann ist ALLES offline!" : "";
            if (!await JS.InvokeAsync<bool>("confirm", $"{guest.Kind} {guest.Name} wirklich {verb}?{warn}")) return;
        }
        busy = true;
        StateHasChanged();
        await Pve.ActionAsync(guest.Node, guest.Type, guest.VmId, action);
        await Task.Delay(2000);
        await Data.RefreshAsync();
        Resolve();
        busy = false;
    }

    public void Dispose() => Data.Changed -= OnChanged;
}
