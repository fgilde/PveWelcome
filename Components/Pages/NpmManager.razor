@page "/admin/npm"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject NpmClient Npm
@inject PveDataService Data

<PageTitle>NPM</PageTitle>

<TopBar />

<div class="page-wrap">
    <div class="page-head">
        <h1>NPM Proxy-Hosts</h1>
        <button class="btn btn-ghost sm" @onclick="Load" disabled="@busy">↻ Refresh</button>
    </div>

    <div class="bindings">
        @foreach (var h in hosts.OrderBy(h => h.DomainNames.FirstOrDefault()))
        {
            <div class="binding @(h.Enabled ? "" : "disabled")">
                <div class="domains">
                    @foreach (var d in h.DomainNames)
                    {
                        <a href="https://@d" target="_blank" rel="noopener">@d ↗</a>
                    }
                </div>
                <div class="target">→ @h.ForwardScheme://@h.ForwardHost:@h.ForwardPort</div>
                <div class="flags npm-actions">
                    <span class="pill @(h.Enabled ? (h.Online ? "on" : "warn") : "off")">@(h.Enabled ? (h.Online ? "online" : "offline") : "disabled")</span>
                    <button class="btn xs" @onclick="() => Toggle(h)">@(h.Enabled ? "Deaktivieren" : "Aktivieren")</button>
                    <button class="btn xs" @onclick="() => StartEdit(h)">Bearbeiten</button>
                    <button class="btn xs danger" @onclick="() => Delete(h)">Löschen</button>
                </div>
            </div>
        }
    </div>

    <h2>@(editId is null ? "Neuer Proxy-Host" : $"Host #{editId} bearbeiten")</h2>
    <div class="npm-form">
        <label>Domains (komma-getrennt)<input @bind="fDomains" placeholder="app.nksoft.de, www.app.nksoft.de" /></label>
        <div class="row">
            <label>Schema
                <select @bind="fScheme"><option value="http">http</option><option value="https">https</option></select>
            </label>
            <label>Ziel-Host<input @bind="fHost" placeholder="192.168.178.x" /></label>
            <label>Port<input type="number" @bind="fPort" /></label>
            <label class="cb">Websockets<input type="checkbox" @bind="fWs" /></label>
        </div>
        <div class="row">
            <button class="btn sm go" @onclick="Save" disabled="@busy">@(editId is null ? "Anlegen" : "Speichern")</button>
            @if (editId is not null)
            {
                <button class="btn sm ghost" @onclick="ResetForm">Abbrechen</button>
            }
        </div>
    </div>

    @if (msg is not null)
    {
        <p class="muted">@msg</p>
    }
</div>

@code {
    private List<NpmHost> hosts = [];
    private int? editId;
    private string fDomains = "";
    private string fScheme = "http";
    private string fHost = "";
    private int fPort = 80;
    private bool fWs = true;
    private string? msg;
    private bool busy;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load() { busy = true; hosts = await Npm.GetHostsAsync(); busy = false; }

    private string[] Domains() => fDomains.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

    private async Task Save()
    {
        var domains = Domains();
        if (domains.Length == 0 || string.IsNullOrWhiteSpace(fHost)) { msg = "Domains und Ziel-Host nötig."; return; }
        busy = true;
        bool ok = editId is null
            ? await Npm.CreateHostAsync(domains, fScheme, fHost.Trim(), fPort, fWs)
            : await Npm.UpdateHostAsync(editId.Value, domains, fScheme, fHost.Trim(), fPort, fWs);
        msg = ok ? "Gespeichert." : "Fehler (NPM-Login/Recht?).";
        busy = false;
        ResetForm();
        await Load();
        await Data.RefreshAsync();
    }

    private void StartEdit(NpmHost h)
    {
        editId = h.Id;
        fDomains = string.Join(", ", h.DomainNames);
        fScheme = h.ForwardScheme;
        fHost = h.ForwardHost;
        fPort = h.ForwardPort;
        fWs = true;
    }

    private void ResetForm()
    {
        editId = null; fDomains = ""; fScheme = "http"; fHost = ""; fPort = 80; fWs = true;
    }

    private async Task Toggle(NpmHost h)
    {
        await Npm.SetEnabledAsync(h.Id, !h.Enabled);
        await Load();
        await Data.RefreshAsync();
    }

    private async Task Delete(NpmHost h)
    {
        await Npm.DeleteHostAsync(h.Id);
        await Load();
        await Data.RefreshAsync();
    }
}
