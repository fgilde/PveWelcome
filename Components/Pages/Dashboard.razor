@page "/dashboard"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable
@inject PveDataService Data
@inject PveClient Pve
@inject IJSRuntime JS

<PageTitle>Dashboard</PageTitle>

<TopBar />

<div class="page-wrap">
    <div class="page-head">
        <h1>Dashboard</h1>
        <div class="head-right">
            @if (Data.LastUpdated != default)
            {
                <span class="muted stamp">@(Data.Refreshing ? "aktualisiert…" : $"vor {Ago()}")</span>
            }
            <button class="btn btn-ghost sm" @onclick="Refresh" disabled="@Data.Refreshing">↻ Refresh</button>
        </div>
    </div>

    @if (Data.Alerts.Count > 0)
    {
        <div class="alerts">
            @foreach (var a in Data.Alerts)
            {
                <div class="alert">⚠ @a</div>
            }
        </div>
    }

    @if (Data.Health is not null)
    {
        var h = Data.Health;
        <section class="health">
            <div class="metric"><span class="label">Node</span><span class="val">@h.Node</span></div>
            <div class="metric"><span class="label">CPU</span><span class="val">@Format.Pct(h.CpuFraction)</span>
                <div class="bar"><i style="width:@(Math.Min(100, h.CpuFraction*100))%"></i></div>
                <Sparkline Values="Data.NodeCpuHist" /></div>
            <div class="metric"><span class="label">RAM</span><span class="val">@Format.Bytes(h.MemUsed) / @Format.Bytes(h.MemMax)</span>
                <div class="bar"><i style="width:@(h.MemMax>0 ? h.MemUsed*100.0/h.MemMax : 0)%"></i></div>
                <Sparkline Values="Data.NodeMemHist" Color="#38bdf8" /></div>
            <div class="metric"><span class="label">Load</span><span class="val">@h.LoadAvg1.ToString("0.00")</span></div>
            <div class="metric"><span class="label">Uptime</span><span class="val">@Format.Uptime(h.Uptime)</span></div>
            @if (Data.UpdatesAvailable > 0)
            {
                <div class="metric"><span class="label">Updates</span>
                    <span class="val"><span class="pill warn">@Data.UpdatesAvailable verfügbar</span></span>
                    <span class="sub muted">apt am Node</span></div>
            }
            <div class="metric">
                <span class="label">RAM zugew.</span>
                <span class="val">@Format.Bytes(AllocatedRam()) / @Format.Bytes(h.MemMax)</span>
                <span class="sub muted">@Data.Guests.Count(g => g.IsRunning)/@Data.Guests.Count Guests laufen</span>
            </div>
        </section>
    }

    @if (Data.Storages.Count > 0)
    {
        <h2>Storage</h2>
        <section class="health storage">
            @foreach (var s in Data.Storages)
            {
                <div class="metric">
                    <span class="label">@s.Name <small>@s.Type</small></span>
                    <span class="val">@Format.Bytes(s.Used) / @Format.Bytes(s.Total)</span>
                    <div class="bar @(s.Fraction > 0.85 ? "hot" : "")"><i style="width:@(Math.Min(100, s.Fraction*100))%"></i></div>
                    <span class="sub muted">@Format.Bytes(s.Avail) frei · @Format.Pct(s.Fraction)</span>
                </div>
            }
        </section>
    }

    <div class="res-head">
        <h2>Ressourcen</h2>
        @if (bkpMsg is not null)
        {
            <span class="muted bkp-msg">@bkpMsg</span>
        }
    </div>
    @if (Data.Guests.Count == 0)
    {
        <p class="muted">@(Data.LastUpdated == default ? "Lade…" : "Keine Ressourcen.")</p>
    }
    else
    {
        <div class="grid">
            @foreach (var g in Data.Guests)
            {
                var served = Data.HostsFor(g);
                <div class="card @(g.IsRunning ? "up" : "down")">
                    <a class="card-head" href="/resource/@g.VmId">
                        <span class="kind">@g.Kind</span>
                        <span class="name">@g.Name</span>
                        <span class="vmid">#@g.VmId</span>
                    </a>
                    <div class="status">
                        <span class="pill @(g.IsRunning ? "on" : "off")">@g.Status</span>
                        @if (g.Ip is not null)
                        {
                            <span class="ip">@g.Ip</span>
                        }
                        @if (served.Count > 0)
                        {
                            <span class="serve-badge" title="@ServedTooltip(served)">🔗 @served.Count</span>
                        }
                    </div>
                    @if (g.IsRunning)
                    {
                        <div class="mini">
                            <span>CPU @Format.Pct(g.CpuFraction)</span>
                            <span>RAM @Format.Bytes(g.MemUsed)/@Format.Bytes(g.MemMax)</span>
                            <span>Disk @Format.Bytes(g.DiskUsed)/@Format.Bytes(g.DiskMax)</span>
                        </div>
                    }
                    @{ var bk = Data.BackupFor(g.VmId); }
                    <div class="bkp @(bk is null ? "none" : "")">
                        @(bk is null ? "kein Backup" : $"Backup {bk.Time.LocalDateTime:dd.MM HH:mm}")
                    </div>
                    <div class="actions">
                        @if (g.IsRunning)
                        {
                            <button class="btn xs" disabled="@IsBusy(g)" @onclick='() => Act(g, "reboot")'>Restart</button>
                            <button class="btn xs danger" disabled="@IsBusy(g)" @onclick='() => Act(g, "shutdown")'>Stop</button>
                        }
                        else
                        {
                            <button class="btn xs go" disabled="@IsBusy(g)" @onclick='() => Act(g, "start")'>Start</button>
                        }
                        <button class="btn xs" disabled="@IsBusy(g)" @onclick="() => BackupNow(g)">Backup</button>
                        <a class="btn xs ghost" href="/resource/@g.VmId">Details →</a>
                    </div>
                </div>
            }
        </div>
    }

    @if (Data.Tasks.Count > 0)
    {
        <h2>Aktivität</h2>
        <div class="tasks">
            @foreach (var t in Data.Tasks.Take(10))
            {
                <div class="task @(t.IsRunning ? "run" : t.Ok ? "ok" : "err")">
                    <span class="tstate">@(t.IsRunning ? "läuft…" : t.Ok ? "✓" : "✗")</span>
                    <span class="tt">@t.Label</span>
                    <span class="ts muted">@t.Start.LocalDateTime.ToString("dd.MM HH:mm")</span>
                </div>
            }
        </div>
    }

    <h2>NPM Bindings <span class="count @(DomainsUp() == DomainsTotal() ? "ok" : "warn")">@DomainsUp()/@DomainsTotal() extern online</span></h2>
    <div class="bindings">
        @foreach (var host in Data.Hosts.OrderBy(h => h.DomainNames.FirstOrDefault()))
        {
            var up = host.DomainNames.Any(d => Data.DomainUp.TryGetValue(d, out var u) && u);
            <div class="binding @(host.Enabled ? "" : "disabled")">
                <div class="domains">
                    @foreach (var d in host.DomainNames)
                    {
                        <a href="https://@d" target="_blank" rel="noopener">@d ↗</a>
                    }
                </div>
                <div class="target">→ @host.ForwardScheme://@host.ForwardHost:@host.ForwardPort</div>
                <div class="flags">
                    @if (!host.Enabled)
                    {
                        <span class="pill off">disabled</span>
                    }
                    else
                    {
                        <span class="pill @(up ? "on" : "warn")">@(up ? "online" : "nicht erreichbar")</span>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string? busyKey;
    private string? bkpMsg;

    private async Task BackupNow(PveGuest g)
    {
        var target = Data.BackupTarget;
        if (string.IsNullOrEmpty(target)) { bkpMsg = "Kein Backup-Ziel konfiguriert — in Settings wählen."; return; }
        if (!await JS.InvokeAsync<bool>("confirm", $"Backup von {g.Name} auf '{target}' starten?")) return;
        var ok = await Data.TriggerBackupAsync(g);
        bkpMsg = ok
            ? $"Backup von {g.Name} → '{target}' gestartet (erscheint in ein paar Minuten)."
            : $"Backup-Start für {g.Name} fehlgeschlagen.";
    }

    private System.Threading.Timer? _ticker;

    protected override async Task OnInitializedAsync()
    {
        Data.Changed += OnChanged;
        _ticker = new System.Threading.Timer(_ => InvokeAsync(StateHasChanged), null, 5000, 5000);
        if (Data.LastUpdated == default) await Data.RefreshAsync();
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private string Ago()
    {
        var s = (int)(DateTime.Now - Data.LastUpdated).TotalSeconds;
        return s < 60 ? $"{s}s" : $"{s / 60}m {s % 60}s";
    }

    private long AllocatedRam() => Data.Guests.Sum(g => g.MemMax);

    private int DomainsTotal() => Data.DomainUp.Count;
    private int DomainsUp() => Data.DomainUp.Count(kv => kv.Value);

    private static string ServedTooltip(List<NpmHost> hosts) =>
        string.Join("\n", hosts.Select(h => $"{string.Join(", ", h.DomainNames)}  (:{h.ForwardPort}, {(h.Online ? "online" : "offline")})"));

    private bool IsBusy(PveGuest g) => busyKey == Key(g);
    private static string Key(PveGuest g) => $"{g.Type}-{g.VmId}";

    private Task Refresh() => Data.RefreshAsync();

    private async Task Act(PveGuest g, string action)
    {
        if (action is "shutdown" or "reboot")
        {
            var verb = action == "shutdown" ? "stoppen" : "neu starten";
            var warn = g.Name == "core" ? " ⚠ core hostet Proxy + Tunnel — dann ist ALLES (auch diese Seite) offline!" : "";
            if (!await JS.InvokeAsync<bool>("confirm", $"{g.Kind} {g.Name} wirklich {verb}?{warn}")) return;
        }
        busyKey = Key(g);
        StateHasChanged();
        await Pve.ActionAsync(g.Node, g.Type, g.VmId, action);
        await Task.Delay(2000);
        await Data.RefreshAsync();
        busyKey = null;
    }

    public void Dispose()
    {
        Data.Changed -= OnChanged;
        _ticker?.Dispose();
    }
}
