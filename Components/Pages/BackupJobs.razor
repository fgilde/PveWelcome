@page "/admin/backups"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@implements IDisposable
@inject PveDataService Data
@inject PveClient Pve
@inject IJSRuntime JS

<PageTitle>Backup-Jobs</PageTitle>

<TopBar />

<div class="page-wrap">
    <h1>Backup-Jobs</h1>
    <p class="muted">Zeitplan, Ziel-Storage und <strong>Aufbewahrung</strong> (wie viele Backups pro Guest behalten werden). 1 spart am meisten Platz.</p>
    @if (msg is not null)
    {
        <p class="muted">@msg</p>
    }

    @if (jobs.Count == 0)
    {
        <p class="muted">@(Data.LastUpdated == default ? "Lade…" : "Keine Backup-Jobs.")</p>
    }
    @foreach (var j in jobs)
    {
        <div class="settings-card">
            <div class="settings-grid">
                <label>Zeit (HH:MM)<input @bind="j.Schedule" placeholder="03:00" /></label>
                <label>Ziel-Storage
                    <select @bind="j.Storage">
                        @foreach (var s in Data.BackupStorages)
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </label>
                <label>Behalten pro Guest<input type="number" min="1" @bind="j.KeepLast" /></label>
                <label class="chk">Alle Guests<input type="checkbox" @bind="j.All" /></label>
                <label class="chk">Aktiv<input type="checkbox" @bind="j.Enabled" /></label>
            </div>
            @if (!j.All)
            {
                <div class="guest-pick">
                    @foreach (var g in Data.Guests)
                    {
                        <label class="chk"><input type="checkbox" checked="@j.Vmids.Contains(g.VmId)"
                            @onchange="e => Toggle(j, g.VmId, (bool)e.Value!)" /> @g.Name <span class="muted">#@g.VmId</span></label>
                    }
                </div>
            }
            <button class="btn sm go" @onclick="() => Save(j)">Speichern</button>
            <button class="btn sm danger" @onclick="() => Del(j)">Löschen</button>
        </div>
    }

    <h2>Neuer Job</h2>
    <div class="settings-card">
        <div class="settings-grid">
            <label>Zeit (HH:MM)<input @bind="nw.Schedule" placeholder="03:00" /></label>
            <label>Ziel-Storage
                <select @bind="nw.Storage">
                    <option value="">(wählen)</option>
                    @foreach (var s in Data.BackupStorages)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </label>
            <label>Behalten pro Guest<input type="number" min="1" @bind="nw.KeepLast" /></label>
            <label class="chk">Alle Guests<input type="checkbox" @bind="nw.All" /></label>
        </div>
        @if (!nw.All)
        {
            <div class="guest-pick">
                @foreach (var g in Data.Guests)
                {
                    <label class="chk"><input type="checkbox" checked="@nw.Vmids.Contains(g.VmId)"
                        @onchange="e => Toggle(nw, g.VmId, (bool)e.Value!)" /> @g.Name <span class="muted">#@g.VmId</span></label>
                }
            </div>
        }
        <button class="btn sm go" @onclick="Create">Anlegen</button>
    </div>

    <h2 style="margin-top:2rem">Vorhandene Backups</h2>
    <p class="muted">Alle Archive pro Guest — mit Größe. Restore (destruktiv) und Löschen.</p>
    @if (bkpMsg is not null)
    {
        <p class="muted">@bkpMsg</p>
    }
    @if (Data.AllBackups.Count == 0)
    {
        <p class="muted">@(Data.LastUpdated == default ? "Lade…" : "Keine Backups vorhanden.")</p>
    }
    else
    {
        @foreach (var grp in Data.AllBackups.GroupBy(b => b.VmId).OrderBy(g => g.Key))
        {
            <div class="settings-card">
                <div class="settings-host">
                    @GuestName(grp.Key) <span class="muted">#@grp.Key · @grp.Count() Backup(s) · @Format.Bytes(grp.Sum(b => b.Size)) gesamt</span>
                </div>
                <div class="snap-list">
                    @foreach (var b in grp.OrderByDescending(b => b.Time))
                    {
                        <div class="snap-row">
                            <span class="snap-name">@b.Time.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</span>
                            <span class="muted">@Format.Bytes(b.Size) · @b.Storage · @b.Type</span>
                            <span class="snap-btns">
                                <button class="btn xs danger" disabled="@busy" @onclick="() => RestoreBackup(b)">Restore</button>
                                <button class="btn xs danger" disabled="@busy" @onclick="() => DeleteBackup(b)">Löschen</button>
                            </span>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private sealed class JobEdit
    {
        public string Id = "";
        public string Schedule = "";
        public string Storage = "";
        public int KeepLast = 1;
        public bool All = true;
        public HashSet<int> Vmids = new();
        public bool Enabled = true;
        public string VmidCsv => string.Join(",", Vmids.OrderBy(x => x));
    }

    private static void Toggle(JobEdit j, int vmid, bool on)
    {
        if (on) j.Vmids.Add(vmid); else j.Vmids.Remove(vmid);
    }

    private List<JobEdit> jobs = [];
    private JobEdit nw = new() { Schedule = "03:00", KeepLast = 1, All = true };
    private string? msg;
    private string? bkpMsg;
    private bool busy;

    private string GuestName(int vmid) => Data.Guests.FirstOrDefault(g => g.VmId == vmid)?.Name ?? $"VM {vmid}";

    private async Task RestoreBackup(BackupInfo b)
    {
        var g = Data.Guests.FirstOrDefault(x => x.VmId == b.VmId);
        if (g is not null && g.IsRunning) { bkpMsg = $"{g.Name} läuft — zum Wiederherstellen erst stoppen."; return; }
        var name = g?.Name ?? $"#{b.VmId}";
        var warn = name == "core" ? "\n\nACHTUNG: core hostet Proxy/Tunnel + diese App — ein Restore killt ALLES!" : "";
        var typed = await JS.InvokeAsync<string>("prompt",
            $"WARNUNG: {name} (#{b.VmId}) wird KOMPLETT mit dem Backup vom {b.Time.LocalDateTime:yyyy-MM-dd HH:mm} überschrieben. Der aktuelle Zustand geht unwiderruflich verloren.{warn}\n\nZum Bestätigen den Namen exakt tippen: {name}");
        if (typed != name) { bkpMsg = "Restore abgebrochen (Name nicht bestätigt)."; return; }
        busy = true; StateHasChanged();
        var err = await Data.RestoreFromAsync(b);
        busy = false;
        bkpMsg = err is null ? "Restore gestartet — läuft im Hintergrund (im Proxmox-Task/Konsole beobachten)." : $"Restore fehlgeschlagen: {err}";
    }

    private async Task DeleteBackup(BackupInfo b)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Backup von {GuestName(b.VmId)} (#{b.VmId}) vom {b.Time.LocalDateTime:dd.MM.yyyy HH:mm} ({Format.Bytes(b.Size)}) löschen? Unwiderruflich.")) return;
        busy = true; StateHasChanged();
        var err = await Data.DeleteBackupAsync(b);
        await Data.RefreshAsync();
        busy = false;
        bkpMsg = err is null ? "Backup gelöscht." : $"Löschen fehlgeschlagen: {err}";
    }

    protected override async Task OnInitializedAsync()
    {
        Data.Changed += OnChanged;
        if (Data.LastUpdated == default) await Data.RefreshAsync();
        Load();
        if (string.IsNullOrEmpty(nw.Storage)) nw.Storage = Data.BackupStorages.FirstOrDefault() ?? "";
    }

    private void OnChanged() => InvokeAsync(() => { Load(); StateHasChanged(); });

    private void Load() => jobs = Data.BackupJobs.Select(j => new JobEdit
    {
        Id = j.Id, Schedule = j.Schedule, Storage = j.Storage,
        KeepLast = Math.Max(1, j.KeepLast), All = j.All, Enabled = j.Enabled,
        Vmids = j.Vmid.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                     .Select(s => int.TryParse(s, out var v) ? v : -1).Where(v => v > 0).ToHashSet()
    }).ToList();

    private async Task Save(JobEdit j)
    {
        if (!j.All && j.Vmids.Count == 0) { msg = "Mindestens einen Guest wählen oder 'Alle Guests'."; return; }
        var err = await Pve.UpdateBackupJobAsync(j.Id, j.Schedule.Trim(), j.Storage, j.KeepLast, j.All, j.VmidCsv, j.Enabled);
        msg = err is null ? "Gespeichert." : $"Fehler: {err}";
        await Data.RefreshAsync();
    }

    private async Task Create()
    {
        if (string.IsNullOrWhiteSpace(nw.Storage)) { msg = "Ziel-Storage wählen."; return; }
        if (!nw.All && nw.Vmids.Count == 0) { msg = "Mindestens einen Guest wählen oder 'Alle Guests'."; return; }
        var err = await Pve.CreateBackupJobAsync(nw.Schedule.Trim(), nw.Storage, nw.KeepLast, nw.All, nw.VmidCsv);
        msg = err is null ? "Job angelegt." : $"Fehler: {err}";
        nw = new() { Schedule = "03:00", KeepLast = 1, All = true, Storage = Data.BackupStorages.FirstOrDefault() ?? "" };
        await Data.RefreshAsync();
    }

    private async Task Del(JobEdit j)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Backup-Job ({(j.All ? "alle Guests" : j.VmidCsv)} → {j.Storage}) löschen?")) return;
        var err = await Pve.DeleteBackupJobAsync(j.Id);
        msg = err is null ? "Gelöscht." : $"Fehler: {err}";
        await Data.RefreshAsync();
    }

    public void Dispose() => Data.Changed -= OnChanged;
}
